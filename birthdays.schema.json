{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/birthdays.schema.json",
  "title": "Birthdays",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "parentId",
      "spouseId",
      "familyName",
      "generation",
      "name",
      "relation",
      "birthYear",
      "gender",
      "birthdayType",
      "birthMonth",
      "birthDay"
    ],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1
      },
      "parentId": {
        "type": ["string", "null"]
      },
      "spouseId": {
        "type": ["string", "null"]
      },
      "familyName": {
        "type": "string",
        "minLength": 1
      },
      "generation": {
        "type": "integer",
        "minimum": 1
      },
      "name": {
        "type": "string",
        "minLength": 1
      },
      "nickName": {
        "type": "string"
      },
      "relation": {
        "type": "string",
        "minLength": 1
      },
      "birthYear": {
        "type": ["integer", "null"],
        "minimum": 1900,
        "maximum": 2100
      },
      "gender": {
        "type": "string",
        "enum": ["male", "female"]
      },
      "birthdayType": {
        "type": "string",
        "enum": ["solar", "lunar"]
      },
      "birthMonth": {
        "type": "integer",
        "minimum": 1,
        "maximum": 12
      },
      "birthDay": {
        "type": "integer",
        "minimum": 1,
        "maximum": 31
      }
    },
    "additionalProperties": false
  }
}
